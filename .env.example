# ============================================================
# OneAI — 環境變數範本
# 複製成 .env 後填值。真實金鑰絕不進 git。
# ============================================================

# ---------- LLM Gateway: OpenRouter (OpenAI 相容,單一入口) ----------
# 所有元件只連這一個 base URL + key;要用哪個模型「不寫死在程式」,
# 改 config/oneai.models.json 的 active 即可(或用 `npm run model <別名>`)。
# key 到 https://openrouter.ai/keys 申請(形如 sk-or-v1-...)。
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=

# ---------- 嵌入 (Embeddings,與對話 LLM 分離) ----------
# 雲端路線:OpenRouter 也支援 /embeddings,可沿用同一把 key。
# 本機路線:EMBEDDING_API_KEY 留空 → 用免費 bge-small-zh(中文佳,免金鑰)。
EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=openai/text-embedding-3-small
# 本機路線(EMBEDDING_API_KEY 留空時生效):中文用 bge-small-zh,免費免金鑰。
RAG_LOCAL_EMBED_MODEL=BAAI/bge-small-zh-v1.5

# ---------- 雲端大腦 LibreChat (Zeabur) ----------
LIBRECHAT_BASE_URL=https://your-librechat.zeabur.app
# LibreChat 認證機密(用強隨機值)
CREDS_KEY=
CREDS_IV=
JWT_SECRET=
JWT_REFRESH_SECRET=
MONGO_URI=mongodb://mongodb:27017/LibreChat

# ---------- ntfy (自架, Zeabur) ----------
NTFY_BASE_URL=https://your-ntfy.zeabur.app
NTFY_TOPIC_APPROVALS=limengyi-approvals
NTFY_TOPIC_NOTIFY=limengyi-notify
NTFY_TOKEN=
# Web Push VAPID (公鑰可進前端;私鑰僅後端)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# ---------- 審核服務 (approval-svc) ----------
APPROVAL_PORT=8787
APPROVAL_BASE_URL=https://your-approval.zeabur.app
APPROVAL_DEFAULT_TIMEOUT_SEC=1800
# 組件間共享密鑰:agent/bridge → 審核服務(/request、/notify、/pending)須帶 Bearer。
# 留空=不鑑權(僅限本機開發);上線「必填」強隨機值。
APPROVAL_TOKEN=
# 本機肉體 worker 專屬密鑰(最小權限:只能拉任務 /tasks/next、回報 /tasks/:id/result)。
# 需同時設在 approval-svc 服務變數,以及你本機跑 worker.py 的環境。留空=停用本機任務佇列。
ONEAI_WORKER_TOKEN=
# 非阻塞輪詢間隔(秒);呼叫端建立審核後以此頻率查 /status/:id
APPROVAL_POLL_INTERVAL_SEC=3
# 審核狀態持久化檔(重啟不遺失待審/決定);容器內請掛載 volume
APPROVAL_DATA_FILE=./data/approval.json

# ---------- 知識庫 / Obsidian ----------
OBSIDIAN_VAULT_PATH=C:\path\to\your\vault
OBSIDIAN_API_KEY=
OBSIDIAN_API_URL=http://127.0.0.1:27123
CHROMADB_HOST=
CHROMADB_PORT=8000

# ---------- Zeabur 部署（rag-svc 手動 redeploy 用）----------
# Dashboard → Account → API → Create token
# 用於：python scripts/zeabur-cli.py redeploy --service-id rag
# 可選 — GraphQL 腳本用；官方 zeabur auth login 則不必填
ZEABUR_TOKEN=

# ---------- 搜尋 (擇一) ----------
TAVILY_API_KEY=
BRAVE_API_KEY=
SERPER_API_KEY=

# ---------- Hands / Antigravity ----------
AGY_BRIDGE_TIMEOUT=600
ANTIGRAVITY_MODEL=

# ---------- Bridge / federation ----------
FEDERATION_ENDPOINT=wss://your-federation-endpoint
